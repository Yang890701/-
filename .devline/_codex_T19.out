+              </span>
+              <input
+                className="control"
+                inputMode="numeric"
+                maxLength={6}
+                pattern="[0-9]{6}"
+                placeholder="202607"
+                value={billingYm}
+                onChange={(event) => setBillingYm(event.target.value)}
+                required
+              />
