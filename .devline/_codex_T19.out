function buildPayload(fields: readonly MasterField[], formState: FormState) {
  return Object.fromEntries(
    fields.map((field) => {
      const rawValue = formState[field.key]?.trim() ?? "";
      if (!rawValue) {
        if (field.required) {
          throw new Error(`${field.label}?箏?憛冑);
        }
        return [field.key, null];
