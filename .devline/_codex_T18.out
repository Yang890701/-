+@router.post("/api/billing/runs/{run_id}/approve")
+def approve_run(
+    run_id: int,
+    current_user: AppUser = Depends(_require_create_user),
+    db: Session = Depends(get_db),
+) -> dict[str, Any]:
+    run = _get_run_or_404(db, run_id)
