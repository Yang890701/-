 166:         "total_amount": sum(calculation.subtotal or 0 for calculation in calculations),
 167:         "by_site": [by_site[site_id] for site_id in sorted(by_site)],
 168:     }
 169: 
 170: 
 171: def compute_golden_case(input_data: dict[str, Any]) -> dict[str, int]:
 172:     mode = _normalize_mode(input_data.get("mode"))
 173:     if mode == "normal":
 174:         usage = _usage_from_golden(input_data)
 175:         amount = _round_ntd(Decimal(usage) * _decimal(input_data["avg_price"]))
 176:     elif mode == "special_price":
 177:         usage = _usage_from_golden(input_data)
 178:         amount = _round_ntd(Decimal(usage) * _decimal(input_data["special_price"]))
 179:     elif mode == "jingping_merge":
 180:         usage = sum(_usage_from_golden(component) for component in input_data["components"])
 181:         amount = _round_ntd(Decimal(usage) * _decimal(input_data["avg_price"]))
 182:     elif mode == "total_sub":
 183:         total_usage = _usage_from_golden(input_data["total"])
 184:         sub_usage = _usage_from_golden(input_data["sub"])
 185:         amount = _round_ntd(Decimal(total_usage - sub_usage) * _decimal(input_data["avg_price"]))
 186:     elif mode == "total_bill_split":
 187:         child_total = sum(int(value) for value in input_data["child_electricity_amounts"])
 188:         amount = int(input_data["taipower_bill_total"]) - child_total
 189:     else:
 190:         raise BillingInputError(f"unsupported golden case mode: {input_data.get('mode')}")
 191:     return {"electricity_amount": amount}
 192: 
 193: 
 194: def preview_billing_run(
 195:     db: Session,
 196:     *,
 197:     billing_ym: str,
 198:     scope: dict[str, Any] | None,
 199:     write_exceptions: bool = False,
 200: ) -> tuple[list[RoomCalculation], dict[str, Any]]:
 201:     billing_ym = validate_billing_ym(billing_ym)
 202:     canonical_scope = canonicalize_scope(scope)
 203:     rooms = _rooms_for_scope(db, canonical_scope)
 204: 
 205:     calculations: list[RoomCalculation] = []
 206:     calculated_by_room: dict[int, RoomCalculation] = {}
 207:     split_rooms: list[Room] = []
 208: 
 209:     for room in rooms:
 210:         mode = _normalize_mode(room.billing_mode)
 211:         if mode == "total_bill_split":
 212:             split_rooms.append(room)
 213:             continue
 214:         calculation = _calculate_non_split_room(
 215:             db,
 216:             room=room,
 217:             billing_ym=billing_ym,
 218:             mode=mode,
 219:             write_exceptions=write_exceptions,
 220:         )
 221:         calculations.append(calculation)
 222:         calculated_by_room[room.id] = calculation
 223: 
 224:     for room in split_rooms:
 225:         calculation = _calculate_total_bill_split_room(
 226:             db,
 227:             room=room,
 228:             billing_ym=billing_ym,
 229:             calculated_by_room=calculated_by_room,
 230:         )
 231:         calculations.append(calculation)
 232:         calculated_by_room[room.id] = calculation
 233: 
 234:     summary = summarize_calculations(calculations)
 235:     return calculations, {
 236:         "billing_ym": billing_ym,
 237:         "scope": canonical_scope,
 238:         "rooms": [asdict(calculation) for calculation in calculations],
 239:         "summary": summary,
 240:     }
 241: 
 242: 
 243: def create_billing_run(
 244:     db: Session,
 245:     *,
 246:     billing_ym: str,
 247:     scope: dict[str, Any] | None,
 248:     idempotency_key: str | None,
 249:     created_by: AppUser,
 250: ) -> BillingRunResult:
 251:     billing_ym = validate_billing_ym(billing_ym)
 252:     canonical_scope = canonicalize_scope(scope)
 253: 
 254:     if idempotency_key:
