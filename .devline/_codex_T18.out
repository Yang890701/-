 470: def reconciliation_report(db: Session, billing_ym: str, scope: dict[str, Any] | None = None) -> dict[str, Any]:
 471:     calculations, _snapshot = preview_billing_run(db, billing_ym=billing_ym, scope=scope, write_exceptions=False)
 472:     computed_by_room = {
 473:         calculation.room_id: calculation.subtotal
 474:         for calculation in calculations
 475:         if calculation.status == "calculated" and calculation.subtotal is not None
 476:     }
 477:     expected_by_room = _latest_rent_confirm_amounts(db, billing_ym)
 478:     room_ids = sorted(set(computed_by_room) | set(expected_by_room))
 479: 
 480:     mismatches: list[dict[str, Any]] = []
 481:     matched = 0
 482:     per_site: dict[int, dict[str, Any]] = {}
 483:     for room_id in room_ids:
 484:         room = db.get(Room, room_id)
 485:         if room is None:
 486:             continue
 487:         computed = computed_by_room.get(room_id)
 488:         expected = expected_by_room.get(room_id)
 489:         diff = None if computed is None or expected is None else computed - expected
 490:         site_bucket = per_site.setdefault(
 491:             room.site_id,
 492:             {"site_id": room.site_id, "computed_total": 0, "expected_total": 0},
 493:         )
 494:         site_bucket["computed_total"] += computed or 0
 495:         site_bucket["expected_total"] += expected or 0
 496:         if diff is not None and abs(diff) <= 1:
 497:             matched += 1
 498:         else:
 499:             mismatches.append(
 500:                 {
 501:                     "room_id": room_id,
 502:                     "room_code": room.room_code,
 503:                     "computed": computed,
 504:                     "expected": expected,
 505:                     "diff": diff,
 506:                 }
 507:             )
 508: 
 509:     return {
 510:         "billing_ym": billing_ym,
 511:         "total_rooms": len(room_ids),
 512:         "matched": matched,
 513:         "mismatched": len(mismatches),
 514:         "mismatches": mismatches,
 515:         "per_site": [per_site[site_id] for site_id in sorted(per_site)],
 516:         "overall": {
 517:             "computed_total": sum(value or 0 for value in computed_by_room.values()),
 518:             "expected_total": sum(value or 0 for value in expected_by_room.values()),
 519:         },
 520:     }
 521: 
 522: 
 523: def _write_billing_audit(
 524:     db: Session,
 525:     actor: AppUser,
 526:     action: str,
 527:     run: BillingRun,
 528:     *,
 529:     row_count: int,
 530: ) -> None:
 531:     db.add(
 532:         AuditLog(
 533:             actor=actor.id,
 534:             action=action,
 535:             table_code="billing_run",
 536:             filters={"run_id": run.id, "billing_ym": run.billing_ym, "version": run.version},
 537:             row_count=row_count,
 538:         )
 539:     )
 540: 
 541: 
 542: def _commit_billing_transition(db: Session, conflict_message: str) -> None:
 543:     try:
 544:         db.commit()
 545:     except IntegrityError as exc:
 546:         db.rollback()
 547:         raise BillingConflictError(conflict_message) from exc
 548: 
 549: 
 550: def _run_details(db: Session, run_id: int) -> list[BillingRunDetail]:
 551:     return list(
 552:         db.scalars(
 553:             select(BillingRunDetail)
 554:             .where(BillingRunDetail.run_id == run_id, BillingRunDetail.deleted_at.is_(None))
 555:             .order_by(BillingRunDetail.room_id.asc(), BillingRunDetail.id.asc())
 556:         )
 557:     )
 558: 
 559: 
 560: def _published_rent_confirm_components(
 561:     db: Session,
 562:     run: BillingRun,
 563:     detail: BillingRunDetail,
 564: ) -> dict[str, Any]:
 565:     contract = _active_contract_for_period(db, detail.room_id, run.billing_ym)
 566:     rent_amount = contract.rent if contract is not None else None
 567:     electricity_amount = detail.subtotal
 568:     fixed_fee_amount = _active_fixed_fee_amount(db, detail.room_id)
 569:     exception_amount = _active_exception_amount(db, detail.room_id, run.billing_ym)
 570:     total_amount = sum(
 571:         _amount_or_zero(value)
 572:         for value in (rent_amount, electricity_amount, fixed_fee_amount, exception_amount)
 573:     )
 574: 
 575:     return {
 576:         "rent_amount": rent_amount,
 577:         "electricity_amount": electricity_amount,
 578:         "fixed_fee_amount": fixed_fee_amount,
 579:         "exception_amount": exception_amount,
 580:         "total_amount": total_amount,
 581:         "amounts": {
 582:             "billing_run_id": run.id,
 583:             "billing_run_detail_id": detail.id,
 584:             "billing_ym": run.billing_ym,
 585:             "run_version": run.version,
 586:             "rent": {
 587:                 "amount": rent_amount,
 588:                 "tenant_contract_id": contract.id if contract is not None else None,
 589:             },
 590:             "electricity": {"amount": electricity_amount},
 591:             "fixed_fee": {"amount": fixed_fee_amount},
 592:             "exception": {"amount": exception_amount},
 593:             "total": {"amount": total_amount},
 594:         },
 595:     }
 596: 
 597: 
 598: def _active_contract_for_period(db: Session, room_id: int, billing_ym: str) -> TenantContract | None:
 599:     period_start, period_end = _billing_month_bounds(billing_ym)
 600:     return db.scalar(
 601:         select(TenantContract)
 602:         .where(
 603:             TenantContract.room_id == room_id,
 604:             TenantContract.deleted_at.is_(None),
 605:             (TenantContract.lease_start_date.is_(None) | (TenantContract.lease_start_date <= period_end)),
 606:             (TenantContract.lease_end_date.is_(None) | (TenantContract.lease_end_date >= period_start)),
 607:         )
 608:         .order_by(TenantContract.lease_start_date.desc().nulls_last(), TenantContract.id.desc())
 609:     )
 610: 
 611: 
 612: def _billing_month_bounds(billing_ym: str) -> tuple[date, date]:
 613:     year = int(billing_ym[:4])
 614:     month = int(billing_ym[4:6])
 615:     period_start = date(year, month, 1)
 616:     if month == 12:
 617:         next_month = date(year + 1, 1, 1)
 618:     else:
 619:         next_month = date(year, month + 1, 1)
 620:     return period_start, date.fromordinal(next_month.toordinal() - 1)

