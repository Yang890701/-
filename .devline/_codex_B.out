}

.control:focus,
.filter-input:focus,
.filter-select:focus {
  border-color: #4a5a6a;
  outline: 2px solid rgba(74, 90, 106, 0.16);
}

.button {
  align-items: center;
  border: 1px solid #4a5a6a;
  display: inline-flex;
  font-weight: 600;
  gap: 8px;
  justify-content: center;
  min-height: 36px;
  padding: 7px 13px;
}

.button-primary {
  background: #4a5a6a;
  color: #fff;
}

.button-secondary {
  background: #fff;
  color: #4a5a6a;
}

.filters {
  border-top: 1px solid #e9e6e0;
  display: grid;
  gap: 12px;
