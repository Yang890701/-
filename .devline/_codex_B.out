+        label: "房號度數上傳",
+        description: "各期房號度數上傳",
+        status: "development",
+      },
+      {
+        label: "平均電價上傳",
+        description: "各期台電帳單平均電價",
+        status: "development",
+      },
+    ],
+  },
+  {
+    title: "資料查詢",
+    rows: [
+      {
+        label: "通用資料檢視",
+        description: "選任一張表→篩選→匯出Excel",
