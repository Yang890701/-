+        label: "房號管理",
+        description: "房號建立/更新/停用",
+        href: "/master/room",
+        status: "development",
+      },
+      {
+        label: "例外費用管理",
+        description: "固定費用與例外款項",
+        status: "development",
+      },
+      {
+        label: "繳租確認管理",
