+      status: "development";
+      href?: `/${string}`;
+    }
+);
+
+export type PortalSection = {
+  title: string;
+  rows: readonly PortalLink[];
+};
+
+export type PortalNotice = {
+  title: string;
+  content?: string;
+  pinned?: boolean;
+  date: string;
+};
+
+export const portalSections = [
+  {
+    title: "主檔管理",
+    rows: [
+      {
+        label: "案場管理",
+        description: "案場建立/更新/停用",
+        href: "/master/site",
+        status: "development",
+      },
+      {
+        label: "電號管理",
+        description: "電號建立/更新/停用",
+        href: "/master/meter",
+        status: "development",
+      },
