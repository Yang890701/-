  padding: 16px 18px 18px;
}

.filter-card {
  display: grid;
  gap: 7px;
}

.filter-row {
  align-items: center;
  display: flex;
  gap: 8px;
}

.filter-row > * {
  min-width: 0;
}

.filter-row .filter-input,
.filter-row .filter-select {
  width: 100%;
}

.checkbox-line {
  align-items: center;
  color: #3f464d;
  display: flex;
  gap: 8px;
  min-height: 36px;
}

.table-card {
  margin-top: 18px;
  overflow: hidden;
}

.table-scroll {
  overflow: auto;
}

table {
  border-collapse: collapse;
  min-width: 100%;
  width: max-content;
}

th,
td {
  border-bottom: 1px solid #ece8e2;
