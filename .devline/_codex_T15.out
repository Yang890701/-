diff --git a/web/app/portal-data.ts b/web/app/portal-data.ts
index 2a236528b6fe78b22fa573f3844f1584a201a952..3aecfc3548126a625393d083aed5eafc4109d0e8
--- a/web/app/portal-data.ts
+++ b/web/app/portal-data.ts
@@ -34,19 +34,19 @@
         label: "案場管理",
         description: "案場建立/更新/停用",
         href: "/master/site",
-        status: "development",
+        status: "available",
       },
       {
         label: "電號管理",
         description: "電號建立/更新/停用",
         href: "/master/meter",
-        status: "development",
+        status: "available",
       },
       {
         label: "房號管理",
         description: "房號建立/更新/停用",
         href: "/master/room",
-        status: "development",
+        status: "available",
       },
