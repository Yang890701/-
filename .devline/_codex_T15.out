diff --git a/api/app/main.py b/api/app/main.py
index 5d0d2852bc94312f9e070f93da29bcddaca7bc96..f2b796d9dcdc2f2dd8c00a929e54214165815b7f
--- a/api/app/main.py
+++ b/api/app/main.py
@@ -5,8 +5,9 @@
