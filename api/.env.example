# 好室後端環境變數範本 — 複製為 .env 後填入實際值(.env 已被 gitignore,勿入版控)

# 資料庫(本機開發用 localhost haoshi_dev;demo 指向線上)
DATABASE_URL=postgresql+psycopg://postgres@localhost:5432/haoshi_dev

# JWT(產生方式見 DEPLOY.md 步驟 1)
JWT_SIGNING_KEYS={"k1":"<至少32字元的隨機secret>"}
JWT_ACTIVE_KID=k1

# Cookie / CORS(本機開發預設;跨網域部署改 true / none / Vercel 網域)
AUTH_COOKIE_SECURE=false
CORS_ALLOWLIST=http://localhost:3000

# AI 資料助理(Genie)——沒填 key 則 AI 問答回錯誤,其餘功能不受影響
ANTHROPIC_API_KEY=sk-ant-<your-key>
ASSISTANT_MODEL=claude-sonnet-4-6
ASSISTANT_EFFORT=low
